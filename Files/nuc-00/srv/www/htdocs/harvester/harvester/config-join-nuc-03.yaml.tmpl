---
scheme_version: 1
server_url: https://${HARVESTER_VIP}
token: ${HARVESTER_TOKEN}
os:
  hostname: nuc-03
  ssh_authorized_keys:
    - ${MANSIBLE_SSH_KEY}
  password: ${HARVESTER_PASSWORD}
  ntp_servers:
    - 0.suse.pool.ntp.org
    - 1.suse.pool.ntp.org
    - 2.suse.pool.ntp.org
  dns_nameservers:
    - ${DNS1_IP}
    - ${DNS2_IP}
    - 8.8.8.8
install:
  skipchecks: true
  mode: join
  management_interface:
    interfaces:
      - name: ${NIC_NAME}
        hwAddr: "${NUC03_MAC}"
    default_route: true
    method: static
    ip: ${NUC03_IP}
    subnet_mask: ${SUBNET_MASK}
    gateway: ${GATEWAY}
    bond_options:
      mode: active-backup
      miimon: 100
  device: /dev/sda
  data_disk: /dev/nvme0n1
  iso_url: http://${ADMIN_IP}/harvester/${HARVESTER_VERSION}/harvester-${HARVESTER_VERSION}-amd64.iso
sans:
  - harvester.${BASE_DOMAIN}
  - ${HARVESTER_VIP}
  - nuc-01.${BASE_DOMAIN}
  - nuc-02.${BASE_DOMAIN}
  - nuc-03.${BASE_DOMAIN}
  - ${NUC01_IP}
  - ${NUC02_IP}
  - ${NUC03_IP}
